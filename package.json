{
  "name": "re-fit",
  "version": "3.0.0",
  "private": true,
  "engines": {
    "node": ">=20.19.0"
  },
  "browserslist": {
    "production": [
      "chrome >= 90",
      "edge >= 90",
      "firefox >= 90",
      "safari >= 14"
    ]
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,css,md,json}\"",
    "prepare": "husky",
    "storybook": "storybook dev -p 6006",
    "storybook:ci-server": "storybook dev -p 6206 --exact-port",
    "build-storybook": "storybook build",
    "storybook:audit": "node scripts/storybook-audit.mjs",
    "test-storybook": "test-storybook --config-dir .storybook",
    "test-storybook:ci": "start-server-and-test \"pnpm storybook:ci-server\" http://127.0.0.1:6206 \"pnpm test-storybook --url http://127.0.0.1:6206\"",
    "storybook:ci": "pnpm storybook:audit && pnpm build-storybook && pnpm test-storybook:ci",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "playwright test --grep @smoke",
    "test:e2e:critical": "playwright test --grep @critical",
    "test:e2e:error": "playwright test --grep @error",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "@aws-sdk/client-cloudwatch": "^3.975.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@react-three/rapier": "^2.2.0",
    "@sentry/nextjs": "^10.42.0",
    "@stomp/stompjs": "^7.2.1",
    "@tanstack/react-query": "^5.90.19",
    "firebase": "^10.13.2",
    "lottie-react": "^2.4.1",
    "meshline": "^3.3.1",
    "motion": "^12.29.2",
    "next": "16.1.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-toastify": "^11.0.5",
    "sockjs-client": "^1.6.1",
    "three": "^0.182.0",
    "web-vitals": "^5.1.0",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@next/bundle-analyzer": "^16.1.6",
    "@opennextjs/aws": "^3.9.16",
    "@playwright/test": "^1.58.2",
    "@storybook/addon-a11y": "^10.2.16",
    "@storybook/addon-docs": "^10.2.16",
    "@storybook/nextjs-vite": "^10.2.16",
    "@storybook/test-runner": "^0.24.2",
    "@tailwindcss/postcss": "^4",
    "@tanstack/react-query-devtools": "^5.91.2",
    "@types/node": "^20",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.53.0",
    "@typescript-eslint/parser": "^8.53.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-boundaries": "^4.2.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "eslint-plugin-storybook": "^10.2.16",
    "google-spreadsheet": "^4.1.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.0",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "sst": "^3.18.1",
    "start-server-and-test": "^2.1.3",
    "storybook": "^10.2.16",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vite": "^7.3.1"
  }
}
